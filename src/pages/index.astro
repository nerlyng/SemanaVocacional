<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content="Astro" />
		<title>Reza por un Seminarista - Diócesis León, Nicaragua</title>
		<link rel="icon" type="image/png" href="/logopv.jpg" />
	<style>
	body {
		font-family: 'Segoe UI', sans-serif;
		text-align: center;
		margin: 0;
		padding: 20px;
		background: linear-gradient(135deg, #f3f0ff, #ffffff);
	}

	h1 {
		color: #3b2e83;
		font-size: 28px;
		margin-bottom: 20px;
	}

	.logo {
		width: 220px;
		margin-bottom: 10px;
	}

	.card {
		background: white;
		padding: 30px;
		border-radius: 20px;
		box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
		max-width: 400px;
		margin: auto;
	}

	button {
		padding: 15px 30px;
		font-size: 18px;
		border: none;
		border-radius: 50px;
		background: linear-gradient(135deg, #5a3ec8, #3b2e83);
		color: white;
		cursor: pointer;
		box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
		transition: all 0.3s ease;
	}

	button:hover {
		transform: scale(1.05);
		background: linear-gradient(135deg, #3b2e83, #5a3ec8);
	}

	#nombre {
		margin-top: 20px;
		font-size: 26px;
		font-weight: bold;
		color: #3b2e83;
	}

	#anno {
		font-size: 18px;
		color: #c49b63;
		margin-top: 5px;
	}

	#parroquia {
		font-size: 16px;
		color: #666;
		margin-top: 5px;
		font-style: italic;
	}

	#foto-container {
		margin-top: 20px;
		display: flex;
		justify-content: center;
	}

	#fotoseminarista {
			width: 200px;
			height: 200px;
			object-fit: cover; /* 🔥 clave */
			object-position: center;
			border-radius: 50%; /* círculo bonito */
			box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
			display: none;
			border: 4px solid #c49b63;
	}

	#contador {
		margin-top: 20px;
		font-size: 16px;
		color: #444;
	}

	.mensaje-compromiso {
	margin-top: 25px;
	padding: 15px 20px;
	background: linear-gradient(135deg, #fff7e6, #fff);
	border-left: 5px solid #c49b63;
	border-radius: 10px;
	font-size: 16px;
	color: #444;
	font-weight: 500;
	box-shadow: 0 4px 10px rgba(0,0,0,0.05);
	}

	#btnCompartir {
	background: #25D366;
	margin-top: 15px;
}

#btnCompartir:hover {
	background: #1ebe5d;
}

	.footer {
		font-size: 14px;
		color: #555;
		text-align: center;
		margin-top: 30px;
		line-height: 1.5;
	}

	.footer small {
		font-size: 11px;
		display: block;
		margin-top: 15px;
	}
</style>
	</head>

	<body>
		<img
			src="logopv.jpg"
			alt="Logo"
			style="width: 250px; margin-bottom: 20px"
		/>
		
		<div class="card">

			<h1>Reza por la vocación de</h1>
			<button id="btn">🙏 Rezaré por</button>

			<div id="nombre"></div>
			<div id="anno"></div>
			<div id="parroquia"></div>
	
			<!-- Contenedor para centrar la foto -->
			<div id="foto-container">
				<img id="fotoseminarista" src="" alt="Foto del seminarista" />
			</div>

			<p id="contador"></p>

			<button id="btnCompartir" style="margin-top: 15px; display:none;">
				📲 Compartir en WhatsApp
			</button>

		</div>
		<div class="footer">
			<div class="mensaje-compromiso">
			🙏 Me comprometo a rezar por su vocacion durante este año.
			</div>
			<p>
				Semana de las vocaciones del 19 al 26 de Abril 2026.
			</p>
			<img id="logodiocesis" src="LogoDiocesisLeon.png" alt="Logo de la Diócesis" style="width: 200px; margin-bottom: 20px"/>
			<small>
				® Medios de comunicación de la Diócesis de León, Nicaragua.
			</small>
		</div>

		<script>
			const btnCompartir = document.getElementById("btnCompartir");

			const btn = document.getElementById("btn") as HTMLButtonElement | null;
			const nombre = document.getElementById("nombre");
			const foto = document.getElementById("fotoseminarista") as HTMLImageElement | null;
			const contador = document.getElementById("contador");
			
			const anno = document.getElementById("anno");
			const parroquia = document.getElementById("parroquia");

			// Función para animar el contador
			function animateCounter(oldValue: number, newValue: number) 
			{
				const duration = 800; // duración en ms
  				const startTime = performance.now();

		  		function update(currentTime: number): void {
    			const elapsed = currentTime - startTime;
		   		const progress = Math.min(elapsed / duration, 1);
    			const value = Math.floor(oldValue + (newValue - oldValue) * progress);
    		if (contador) {  contador.textContent = `Total de intenciones: ${value}`; }
    			if (progress < 1) requestAnimationFrame(update);
  				}
	  				requestAnimationFrame(update);
			}

			 // Función para obtener el total de intenciones
 			let lastTotal = 0;

			async function fetchTotal() {
				if (!contador) return; // ⚠️ salir si el elemento no existe
   			 try {
			   	   const res = await fetch("/api/intenciones-count");
  			    if (!res.ok) throw new Error("Error al obtener el total");
  			    const data = await res.json();
				 const newTotal = data.total;
				 animateCounter(lastTotal, newTotal);
   				 lastTotal = newTotal;
  			   // contador.textContent = `Total de intenciones: ${data.total}`;
 			   } catch (err) {
 			     contador.textContent = "No se pudo obtener el total";
  			    console.error(err);
  			  }
			} 

			// Ejecutar al cargar la página
 			if (localStorage.getItem("yaRezo"))
			{		fetchTotal();}

			if (btn && nombre && foto) {
				btn.addEventListener("click", async () => {
					
					if (btn && localStorage.getItem("yaRezo")) {
						btn.disabled = true;
						btn.style.display = "none";
						btn.textContent = "🙏 Ya estás rezando";
					}
					
					localStorage.setItem("yaRezo", "true");

					nombre.textContent = "Cargando...";
					foto.style.display = "none";

					try {
						const res = await fetch("/api/nombre");
			

						let data = await res.json();
						if (Array.isArray(data)) data = data[0];

						if (!data || !data.nombre) {
							nombre.textContent = "No hay seminaristas disponibles.";
							foto.style.display = "none";
							return;
						}

						// Mostrar nombre
						nombre.textContent = data.nombre;
						if (anno) {
 						 anno.textContent = data.anno ?? "";
				}							

				if (parroquia) {
  				parroquia.textContent = data.parroquia ?? "";
					}

						// Mostrar foto si existe
						if (data.foto) {
							foto.src = data.foto;
							foto.style.display = "block";
						} else {
							foto.style.display = "none";
						}
					//	let lastTotal = 0;

					// Actualizar el contador después de insertar la intención
        			fetchTotal();
					
					//Poner lo de compartir WhatsApp
					if (btnCompartir) 
					{
						btnCompartir.style.display = "inline-block";
						btnCompartir.onclick = () => {

						const texto = `🙏 Hoy rezaré por ${data.nombre}
						📍 ${data.parroquia ?? ""}
						🎓 ${data.anno ?? ""}
						Únete a esta iniciativa de oración 🙌
						https://semanavocacional.vercel.app/ `;

						const url = `https://wa.me/?text=${encodeURIComponent(texto)}`;
						window.open(url, "_blank");
						};
					}
					
					} catch (err) {
						nombre.textContent = "❌ Error al obtener el seminarista.";
						foto.style.display = "none";
						console.error(err);
					}
				});
			}
		</script>
	</body>
</html>
